# Tushare Pro API token —— 自备(注册见 https://tushare.pro)。
# 本项目基于 8000 积分/年档位(完整接口 + 500 次/分限速);免费 / 低积分版功能受限。
# 复制本文件为 .env 并填入你自己的 token。.env 已 gitignore,绝不提交真实 token。
TUSHARE_API_KEY=your_tushare_token_here

# LLM 洞见层(可选,公司分析报告用)。OpenAI 兼容 API,模型可换(DeepSeek / GLM / MiniMax)。
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
